  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "noEmit": true
  },
  "include": ["vite.config.ts", "electron", "src/types"]
}
