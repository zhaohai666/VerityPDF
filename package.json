{
  "name": "verity-pdf",
  "version": "0.0.1",
  "description": "A professional PDF annotation and review tool built with Electron + PDF.js + Konva.js",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "author": "VerityPDF Team <veritypdf@example.com>",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "dev:typecheck": "tsc --project tsconfig.dev.json --noEmit",
    "build:dir": "vite build && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src/ electron/ --ext .ts,.tsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src/ electron/ --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win",
    "pack:linux": "electron-builder --linux",
    "build:verify": "vite build && electron-builder --mac --dir"
  },
  "dependencies": {
    "@paddleocr/paddleocr-js": "^0.4.2",
    "antd": "^5.20.0",
    "better-sqlite3": "^12.11.1",
    "canvas": "^3.2.3",
    "electron-store": "^8.2.0",
    "i18next": "^23.12.0",
    "konva": "^9.3.0",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.0",
    "quickjs-emscripten": "^0.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "react-konva": "^18.2.10",
    "sm-crypto": "^0.4.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.veritypdf.app",
    "productName": "VerityPDF",
    "copyright": "Copyright © 2024 VerityPDF Team",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/fonts",
        "to": "fonts",
        "filter": [
          "**/*.ttf",
          "**/*.otf",
          "**/*.ttc"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*",
      "node_modules/canvas/**/*",
      "node_modules/@paddleocr/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icons/mac/icon.icns",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/win/icon.ico",
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "VerityPDF"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/png",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Office"
    },
    "publish": {
      "provider": "github",
      "owner": "zhaohai666",
      "repo": "VerityPDF",
      "releaseType": "release"
    }
  }
}
