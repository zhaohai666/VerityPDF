  "samples": [
    {
      "id": "basic-text",
      "name": "基础文本 PDF",
      "file": "basic-text.pdf",
      "category": "basic",
      "description": "纯文本内容，无复杂排版",
      "expectedResults": {
        "render": true,
        "textExtraction": true,
        "search": true,
        "annotations": true
      }
    },
    {
      "id": "cjk-content",
